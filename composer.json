{
    "name": "web3php/web3php",
    "description": "Multi-blockchain PHP integration library. Ethereum, Bitcoin, Solana, Tron, Polygon, BSC, Avalanche, Arbitrum, Optimism, Base and more. Includes FakeChain for local testing.",
    "type": "library",
    "license": "MIT",
    "keywords": ["blockchain", "ethereum", "bitcoin", "solana", "tron", "web3", "polygon", "bsc", "evm", "crypto", "fakechain", "hd-wallet", "bip39", "bip44"],
    "homepage": "https://github.com/web3php/web3php",
    "authors": [
        {
            "name": "Web3PHP",
            "role": "Developer"
        }
    ],
    "require": {
        "php": ">=8.1",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-bcmath": "*",
        "ext-gmp": "*",
        "ext-hash": "*",

        "kornrunner/keccak": "^0.2",
        "simplito/elliptic-php": "^1.0",

        "kornrunner/ethereum-offline-raw-tx": "^0.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "files": [
            "src/Web3PHP.php",
            "src/MnemonicWallet.php",
            "src/FakeChain.php"
        ]
    },
    "autoload-dev": {
        "files": [
            "tests/bootstrap.php"
        ]
    },
    "scripts": {
        "test": "phpunit --testdox tests/"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
